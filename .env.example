# ================================
# PyScript.tech - Environment Variables
# ================================

# EmailJS Configuration
REACT_APP_EMAILJS_SERVICE_ID=your_service_id
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key

# Supabase
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Google Analytics 4
REACT_APP_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager
REACT_APP_GTM_ID=GTM-XXXXXXX

# Microsoft Clarity
REACT_APP_CLARITY_PROJECT_ID=your_clarity_project_id

# API Configuration (legacy - replaced by Supabase)
# REACT_APP_API_URL=http://localhost:8000/api

# Strapi CMS (Blog)
REACT_APP_STRAPI_URL=http://localhost:1337

# WhatsApp
REACT_APP_WHATSAPP_NUMBER=5521980292791

# ProFlow Integration (frontend-only, non-sensitive)
REACT_APP_PROFLOW_PORTAL_URL=https://proflow.pro

# ProFlow Integration (Edge Function / server-side only)
# NEVER expose these values in the React frontend
PROFLOW_API_URL=https://api.proflow.pro
PROFLOW_PYSCRIPT_ENDPOINT=/api/v1/projects/pyscript/
PROFLOW_SERVICE_TOKEN=<jwt-do-gestor-pyscript>
PROFLOW_REFRESH_TOKEN=<refresh-token-opcional>
PROFLOW_PORTAL_URL=https://proflow.pro

# Permission control for ProFlow integration
PYSCRIPT_ALLOWED_ADMIN_EMAILS=leonardorfragoso@gmail.com

# Supabase service role key (used only by Edge Functions)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Mailchimp Newsletter
REACT_APP_MAILCHIMP_API_KEY=your_api_key
REACT_APP_MAILCHIMP_SERVER_PREFIX=us12
REACT_APP_MAILCHIMP_AUDIENCE_ID=your_audience_id

# Hotjar (Optional)
REACT_APP_HOTJAR_ID=your_hotjar_id

# Facebook Pixel (Optional)
REACT_APP_FB_PIXEL_ID=your_pixel_id
