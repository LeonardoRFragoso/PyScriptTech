# ================================
# PyScript.tech - Environment Variables
# ================================

# EmailJS Configuration
REACT_APP_EMAILJS_SERVICE_ID=your_service_id
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key

# Google Analytics 4
REACT_APP_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# API Configuration
REACT_APP_API_URL=http://localhost:8000/api

# Strapi CMS (Blog)
REACT_APP_STRAPI_URL=http://localhost:1337

# WhatsApp
REACT_APP_WHATSAPP_NUMBER=5521980292791

# Mailchimp Newsletter
REACT_APP_MAILCHIMP_API_KEY=your_api_key
REACT_APP_MAILCHIMP_SERVER_PREFIX=us12
REACT_APP_MAILCHIMP_AUDIENCE_ID=your_audience_id

# Hotjar (Optional)
REACT_APP_HOTJAR_ID=your_hotjar_id

# Facebook Pixel (Optional)
REACT_APP_FB_PIXEL_ID=your_pixel_id
